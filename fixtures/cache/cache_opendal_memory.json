{
	"id": "cache_opendal_memory",
	"category": "cache",
	"description": "Cache hit with OpenDAL memory backend returns cached response on repeat request",
	"api": {
		"method": "chat",
		"request": {
			"model": "openai/gpt-4o",
			"messages": [
				{
					"role": "user",
					"content": "Hello"
				}
			]
		},
		"mock_response": {
			"status": 200,
			"body": {
				"id": "chatcmpl-opendal-mem-001",
				"object": "chat.completion",
				"created": 1711000000,
				"model": "gpt-4o",
				"choices": [
					{
						"index": 0,
						"message": {
							"role": "assistant",
							"content": "Hi there!"
						},
						"finish_reason": "stop"
					}
				],
				"usage": {
					"prompt_tokens": 5,
					"completion_tokens": 2,
					"total_tokens": 7
				}
			}
		}
	},
	"assertions": {
		"expect_success": true,
		"cache_hit": true
	},
	"tags": ["cache", "opendal"],
	"skip": {}
}
