{
	"id": "ocr_url_document",
	"category": "ocr",
	"description": "OCR request with a document URL input",
	"api": {
		"method": "ocr",
		"request": {
			"model": "mistral/mistral-ocr-latest",
			"document": {
				"type": "document_url",
				"url": "https://example.com/doc.pdf"
			}
		},
		"mock_response": {
			"status": 200,
			"body": {
				"pages": [
					{
						"index": 0,
						"markdown": "# Test Document\n\nThis is a test."
					}
				],
				"model": "mistral/mistral-ocr-latest"
			}
		}
	},
	"assertions": {
		"response_not_null": true
	},
	"tags": ["ocr", "smoke"],
	"skip": {}
}
